FROM node:25
WORKDIR /app/server
COPY package*.json .

ARG CLIENT_HOST
ARG CLIENT_PORT
ARG DB_HOST
ARG JWT_PRIVATE_KEY
ARG SERVER_PORT
ENV CLIENT_HOST=$CLIENT_HOST
ENV CLIENT_PORT=$CLIENT_PORT
ENV DB_HOST=$DB_HOST
ENV JWT_PRIVATE_KEY=$JWT_PRIVATE_KEY
ENV SERVER_PORT=$SERVER_PORT

RUN npm install
COPY . .
EXPOSE 3000
CMD [ "npm", "start" ]